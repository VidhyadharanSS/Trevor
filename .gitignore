# ─── Dependencies ──────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build output (frontend) ───────────────────────────────────────────────
dist/
dist-ssr/
build/
*.local

# ─── Rust / Tauri ──────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/gen/
src-tauri/WixTools/
src-tauri/Cargo.lock.bak

# ─── Generated icons (regenerated in CI from icons/icon.svg) ───────────────
src-tauri/icons/*.png
src-tauri/icons/*.ico
src-tauri/icons/*.icns
!src-tauri/icons/icon.svg
!src-tauri/icons/.gitkeep

# ─── TypeScript ────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── IDE / Editors ─────────────────────────────────────────────────────────
.vscode/
.idea/
.zcode/
*.swp
*.swo
*.iml

# ─── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Env / secrets ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Logs ──────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# ─── Caches ────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.npm/

# ─── Test output ───────────────────────────────────────────────────────────
coverage/
*.lcov
