# Normalise line endings to LF for source code
* text=auto eol=lf

# Force LF on shell scripts and config
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.css       text eol=lf
*.html      text eol=lf

# Force CRLF for Windows scripts
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary files (no diff/merge)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.icns      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary

# Linguist hints — keep generated/lock files out of language stats
package-lock.json   linguist-generated=true
src-tauri/Cargo.lock linguist-generated=true
docs/screenshots/*  linguist-documentation=true
